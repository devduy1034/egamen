 alt="<?php echo \html_entity_decode(data_get($item, 'name', 'Sản phẩm')??'', ENT_QUOTES, 'UTF-8'); ?>"
 title="<?php echo \html_entity_decode(data_get($item, 'name', 'Sản phẩm')??'', ENT_QUOTES, 'UTF-8'); ?>">
