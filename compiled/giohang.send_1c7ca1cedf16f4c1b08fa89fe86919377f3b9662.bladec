 </h3>
 <?php $__currentLoopData = $properties; $this->addLoop($__currentLoopData);$this->getFirstLoop();
 foreach($__currentLoopData as $property): $loop = $this->incrementLoopIndices();  ?>
 <?php 
 $propertyName = '';
 if (is_array($property)) {
 $propertyName = (string) ($property['namevi'] ?? '');
 } elseif (is_object($property)) {
 $propertyName = (string) ($property->namevi ?? '');
 }
 $propertyName = trim($propertyName);
 ?>
 <?php if($propertyName !== ''): ?>
 <p style="margin:0;color:#0f5db7"><?php echo \html_entity_decode($propertyName??'', ENT_QUOTES, 'UTF-8'); ?></p>
 <?php endif; ?>
 <?php endforeach; $this->popLoop(); $loop = $this->getFirstLoop(); ?>
 </td>

 <td align="right" style="padding:6px 9px" valign="top">
 <div>
 <strong><?php echo \html_entity_decode(Func::formatMoney($unitPrice)??'', ENT_QUOTES, 'UTF-8'); ?></strong>
 <?php if($salePrice > 0 && $regularPrice > $salePrice): ?>
 <div style="color:#888;text-decoration:line-through">
 <?php echo \html_entity_decode(Func::formatMoney($regularPrice)??'', ENT_QUOTES, 'UTF-8'); ?>

 </div>
 <?php endif; ?>
